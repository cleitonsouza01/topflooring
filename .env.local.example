# ---- Public site config (safe to expose) ----
# Canonical origin used for metadata, canonical URLs, OG image, sitemap, robots.
NEXT_PUBLIC_SITE_URL=https://www.topflooringorlando.com

# Cloudflare Turnstile site key for the estimate form (public — safe to expose).
# Inlined at BUILD time, so it must be set in the Cloudflare Pages build environment
# (Settings → Environment variables), not the Functions secret store. If unset, the
# form skips Turnstile entirely and still works (fail-open).
# For local dev, Cloudflare's always-passing test key works without a real widget:
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# The matching request-time secret (TURNSTILE_SECRET_KEY) goes in .dev.vars — see below.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- Lead form / notifygw.com ----
# NOT read by the /api/lead Cloudflare Pages Function — this section is reference only.
# To actually change these: edit .dev.vars for local testing (`wrangler pages dev`), or the
# Cloudflare Pages dashboard → Settings → Environment variables for production.
# API key from notifygw.com (format: ngw_...)
NOTIFYGW_API_KEY=ngw_xxxxxxxxxxxxxxxxxxxx
# Optional: email instance id; required only if more than one email instance is registered.
NOTIFYGW_INSTANCE=
# Where estimate-request notifications are delivered.
# One address, or several separated by commas — each gets its own email.
LEAD_TO_EMAIL=roberto.topflooring@gmail.com
